{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "primitive_type": { 
      "type": "string",
      "enum": ["note_stack", "timeline", "scale", "flow_path", "stacked_bars", "container_transfer"]
    },
    "bound_variables": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "variable_id": { "type": "string" },
          "drives": { "type": "string" }
        },
        "required": ["variable_id", "drives"],
        "additionalProperties": false
      }
    },
    "bound_to_widget_input": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pedagogical_justification": { "type": "string" }
  },
  "required": ["primitive_type", "bound_variables", "pedagogical_justification"],
  "additionalProperties": false
}
